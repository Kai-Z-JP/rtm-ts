{
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "sample:build": "pnpm --filter @rtmx/sample rtmx build",
    "clean": "pnpm -r clean",
    "test": "vitest run",
    "lint": "eslint \"packages/*/src/**/*.ts\"",
    "lint:fix": "eslint \"packages/*/src/**/*.ts\" --fix",
    "format": "prettier --write \"packages/*/src/**/*.ts\"",
    "format:check": "prettier --check \"packages/*/src/**/*.ts\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.59.0",
    "vitest": "^1.0.0"
  }
}
