{
  "name": "@rtm-ts/sample",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "pregen": "node -e \"require('fs').rmSync('generated',{recursive:true,force:true})\"",
    "gen": "rtmx generate",
    "prebuild": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "rtmx build",
    "prezip": "pnpm run build",
    "zip": "rtmx zip",
    "clean": "node -e \"['dist','generated'].forEach(d=>require('fs').rmSync(d,{recursive:true,force:true}))\""
  },
  "dependencies": {
    "rtm-ts": "workspace:*"
  }
}
